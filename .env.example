# Camera (do not commit the real password)
CAMERA_RTSP_URL=rtsp://user:pass@rp-rinihue/ec6_ptz
# Seconds to let the H.265 stream stabilize before selecting a snapshot keyframe.
SNAPSHOT_WARMUP_SECONDS=10

# Existing WAHA service. Use its Docker service name when on the same network.
WAHA_URL=http://waha:3000
WAHA_API_KEY=
WAHA_SESSION=default

# Optional Telegram fallback. You can also configure the bot securely from
# Configuración > Telegram after the application starts.
TELEGRAM_BOT_TOKEN=

# Used by the scheduler and shown in timestamps.
TZ=America/Santiago

# Protect the mini frontend/API. Generate a long random value before deployment.
APP_API_TOKEN=change-this-before-deploying
